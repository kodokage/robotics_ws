<?xml version="1.0"?>
<robot name="my_robot">
	<link name="base_link">
		<visual>
			<geometry>
				<box size="1 0.5 0.3"/>
			</geometry>
		</visual>
	</link>

	<link name="laser_link">
		<visual>
			<geometry>
				<cylinder radius="0.1" length="0.2" />
			</geometry>
		</visual>
	</link>

	<joint name="laser_joint" type="fixed">
		<parent link="base_link" />
		<child link="laser_link"/>

		<origin xyz="0.5 0 0.3" rpy="0 0 0" />
	</joint>

</robot>
